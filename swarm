#!/usr/bin/env bash
set -euo pipefail

# ─── Swarm: Pipeline Orchestrator for Coding Agents ─────────────────────────
# Runs a sequential pipeline of specialized agent roles through tmux panes.
# Each stage streams output visibly and passes context via files.

SWARM_DIR="$(cd "$(dirname "$0")" && pwd)"
TMUX_BIN="/opt/homebrew/bin/tmux"
CLAUDE="/opt/homebrew/bin/claude"
CONFIG="$SWARM_DIR/swarm.json"
ROLES_DIR="$SWARM_DIR/roles"
SESSION_NAME="swarm"
PANE_BASE_INDEX=0  # Will be detected from tmux config
POLL_INTERVAL=3
STAGE_TIMEOUT=1800  # 30 minutes default
RESUME_PATH=""

# ─── Layout State ─────────────────────────────────────────────────────────────
# Parallel arrays for stage -> pane ID mapping (bash 3.x compatible)
STAGE_NAMES=()    # Stage names
STAGE_PANES=()    # Corresponding pane IDs
MAIN_PANE_STAGE=""            # Stage currently in main pane
MAIN_PANE_ID=""               # Pane ID of the large left pane

# ─── Error Recovery ──────────────────────────────────────────────────────────

CROSS_STAGE_RETRY_COUNT=0
MAX_CROSS_STAGE_RETRIES=3
ACTIVE_FEEDBACK_FILE=""
RETRY_BACKOFFS=(10 30 60)

# ─── Colors ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Helpers ─────────────────────────────────────────────────────────────────

die() { echo -e "${RED}error:${NC} $*" >&2; exit 1; }
info() { echo -e "${BLUE}swarm:${NC} $*"; }
success() { echo -e "${GREEN}swarm:${NC} $*"; }
warn() { echo -e "${YELLOW}swarm:${NC} $*"; }
uppercase() { echo "$1" | tr '[:lower:]' '[:upper:]'; }

# ─── Status Colors (tmux) ─────────────────────────────────────────────────────

get_status_bg() {
    case "$1" in
        PENDING)           echo "colour240" ;;  # Gray
        RUNNING)           echo "colour39"  ;;  # Cyan
        DONE)              echo "colour40"  ;;  # Green
        FAILED)            echo "colour196" ;;  # Red
        TIMEOUT)           echo "colour208" ;;  # Orange
        RETRY)             echo "colour226" ;;  # Yellow
        VALIDATION_FAILED) echo "colour202" ;;  # Dark orange
        *)                 echo "colour240" ;;
    esac
}

get_status_fg() {
    case "$1" in
        PENDING) echo "colour250" ;;  # Dim
        RETRY)   echo "colour232" ;;  # Dark for yellow bg
        *)       echo "colour231" ;;  # Bright white
    esac
}

# ─── Pane Border Helpers ──────────────────────────────────────────────────────

# Set stage -> pane ID mapping
set_stage_pane() {
    local stage="$1" pane_id="$2"
    local i
    for ((i = 0; i < ${#STAGE_NAMES[@]}; i++)); do
        if [[ "${STAGE_NAMES[$i]}" == "$stage" ]]; then
            STAGE_PANES[$i]="$pane_id"
            return 0
        fi
    done
    # Not found, add new entry
    STAGE_NAMES+=("$stage")
    STAGE_PANES+=("$pane_id")
}

# Get pane ID for stage
get_stage_pane() {
    local stage="$1"
    local i
    for ((i = 0; i < ${#STAGE_NAMES[@]}; i++)); do
        if [[ "${STAGE_NAMES[$i]}" == "$stage" ]]; then
            echo "${STAGE_PANES[$i]}"
            return 0
        fi
    done
    echo ""
}

update_pane_border() {
    local stage="$1" status="$2" extra="${3:-}"
    local pane_id
    pane_id=$(get_stage_pane "$stage")
    [[ -n "$pane_id" ]] || return 0

    local bg fg stage_upper
    bg=$(get_status_bg "$status")
    fg=$(get_status_fg "$status")
    stage_upper=$(uppercase "$stage")

    local label="[$status]"
    [[ -n "$extra" ]] && label="[$status] $extra"

    local format="#[fg=${fg},bg=${bg},bold] ${stage_upper} ${label} #[default]"
    "$TMUX_BIN" select-pane -t "$pane_id" -T "$format" 2>/dev/null || true
}

swap_to_main() {
    local stage="$1"
    [[ "$stage" == "$MAIN_PANE_STAGE" ]] && return 0
    [[ -z "$MAIN_PANE_ID" ]] && return 0

    local incoming
    incoming=$(get_stage_pane "$stage")
    [[ -z "$incoming" ]] && return 0

    local outgoing="$MAIN_PANE_ID"
    local old_stage="$MAIN_PANE_STAGE"

    "$TMUX_BIN" swap-pane -s "$incoming" -t "$outgoing" 2>/dev/null || return 0

    # Update mappings: pane contents swapped, so swap the pane IDs for each stage
    set_stage_pane "$stage" "$outgoing"
    if [[ -n "$old_stage" ]]; then
        set_stage_pane "$old_stage" "$incoming"
        # Re-apply the old stage's border to its new pane location
        # Get its status from run.json
        local old_status="DONE"  # Default to DONE since it completed
        if [[ -f "$SWARM_RUNTIME/run.json" ]]; then
            old_status=$(jq -r --arg s "$old_stage" '.stages[$s].status // "done"' "$SWARM_RUNTIME/run.json")
            case "$old_status" in
                done)              old_status="DONE" ;;
                failed)            old_status="FAILED" ;;
                timeout)           old_status="TIMEOUT" ;;
                validation_failed) old_status="VALIDATION_FAILED" ;;
                *)                 old_status="DONE" ;;
            esac
        fi
        update_pane_border "$old_stage" "$old_status"
    fi
    MAIN_PANE_STAGE="$stage"
}

usage() {
    cat <<'EOF'
Usage: swarm --repo <path> --ticket <description|url|file>
       swarm --repo <path> --resume <worktree_path>

Options:
  --repo PATH              Path to the git repository (relative or absolute)
  --ticket TICKET          Ticket: description string, GitHub issue URL/ref, or file path
  --resume WORKTREE_PATH   Resume a previously interrupted pipeline
  --session NAME           tmux session name (default: swarm)
  --timeout SECONDS        Per-stage timeout in seconds (default: 1800)
  --help                   Show this help

The --ticket flag auto-detects the input type:
  - GitHub URL:   https://github.com/owner/repo/issues/42
  - GitHub ref:   owner/repo#42
  - File path:    ./ticket.md or /path/to/ticket.md (must exist on disk)
  - Description:  anything else is treated as an inline ticket

Examples:
  swarm --repo ../myapp --ticket "add a health check endpoint"
  swarm --repo ../myapp --ticket owner/repo#42
  swarm --repo ../myapp --ticket https://github.com/owner/repo/issues/42
  swarm --repo ../myapp --ticket ./ticket.md
  swarm --repo ../myapp --resume ../myapp-swarm-20250101-120000
EOF
    exit 0
}

# ─── Prerequisite Checks ────────────────────────────────────────────────────

check_prerequisites() {
    local missing=()
    [[ -x "$TMUX_BIN" ]] || missing+=(tmux)
    command -v jq &>/dev/null || missing+=(jq)
    [[ -x "$CLAUDE" ]] || missing+=(claude)
    command -v gh &>/dev/null || missing+=(gh)
    command -v git &>/dev/null || missing+=(git)

    if [[ ${#missing[@]} -gt 0 ]]; then
        die "missing prerequisites: ${missing[*]}"
    fi
}

# ─── Auth Pre-flight ─────────────────────────────────────────────────────────

AUTH_PROVIDER=""

check_auth() {
    info "checking claude authentication..."

    local auth_json
    auth_json=$("$CLAUDE" auth status --json 2>&1) || {
        die "failed to check auth status — run: claude auth login"
    }

    local logged_in api_provider
    logged_in=$(echo "$auth_json" | jq -r '.loggedIn // false')
    api_provider=$(echo "$auth_json" | jq -r '.apiProvider // "unknown"')

    if [[ "$logged_in" != "true" ]]; then
        die "claude not authenticated — run: claude auth login"
    fi

    AUTH_PROVIDER="$api_provider"
    success "authenticated via ${api_provider}"
}

# ─── Config Helpers ──────────────────────────────────────────────────────────

get_pipeline() {
    jq -r '.pipeline[]' "$CONFIG"
}

get_stage_model() {
    local stage="$1"
    local override
    override=$(jq -r --arg s "$stage" '.stage_overrides[$s].model // empty' "$CONFIG")
    if [[ -n "$override" ]]; then
        echo "$override"
    else
        jq -r '.defaults.model' "$CONFIG"
    fi
}

get_stage_budget() {
    local stage="$1"
    local override
    override=$(jq -r --arg s "$stage" '.stage_overrides[$s].max_budget_usd // empty' "$CONFIG")
    if [[ -n "$override" ]]; then
        echo "$override"
    else
        jq -r '.defaults.max_budget_usd' "$CONFIG"
    fi
}

get_stage_max_retries() {
    local stage="$1"
    local override
    override=$(jq -r --arg s "$stage" '.stage_overrides[$s].max_retries // empty' "$CONFIG")
    if [[ -n "$override" ]]; then
        echo "$override"
    else
        jq -r '.defaults.max_retries // 3' "$CONFIG"
    fi
}

get_retry_backoffs() {
    local backoffs
    backoffs=$(jq -r '.defaults.retry_backoffs // empty' "$CONFIG")
    if [[ -n "$backoffs" ]]; then
        jq -r '.defaults.retry_backoffs[]' "$CONFIG"
    else
        echo "10"
        echo "30"
        echo "60"
    fi
}

get_max_cross_stage_retries() {
    jq -r '.defaults.max_cross_stage_retries // 3' "$CONFIG"
}

# ─── Argument Parsing ────────────────────────────────────────────────────────

parse_args() {
    REPO_PATH=""
    TICKET=""
    local ticket_raw=""

    [[ $# -eq 0 ]] && usage
    [[ "$1" == "--help" ]] && usage

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo)
                [[ $# -ge 2 ]] || die "--repo requires a path"
                REPO_PATH="$2"
                shift 2
                ;;
            --ticket)
                [[ $# -ge 2 ]] || die "--ticket requires a value"
                ticket_raw="$2"
                shift 2
                ;;
            --resume)
                [[ $# -ge 2 ]] || die "--resume requires a worktree path"
                RESUME_PATH="$2"
                shift 2
                ;;
            --session)
                [[ $# -ge 2 ]] || die "--session requires an argument"
                SESSION_NAME="$2"
                shift 2
                ;;
            --timeout)
                [[ $# -ge 2 ]] || die "--timeout requires an argument"
                STAGE_TIMEOUT="$2"
                shift 2
                ;;
            --help)
                usage
                ;;
            -*)
                die "unknown option: $1"
                ;;
            *)
                # Legacy positional args: first is repo, second is ticket
                if [[ -z "$REPO_PATH" ]]; then
                    REPO_PATH="$1"
                elif [[ -z "$ticket_raw" ]]; then
                    ticket_raw="$1"
                else
                    die "unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    # Resolve repo path
    [[ -n "$REPO_PATH" ]] || die "no repo path provided (use --repo)"
    REPO_PATH="$(cd "$REPO_PATH" 2>/dev/null && pwd)" || die "invalid repo path: $REPO_PATH"
    [[ -d "$REPO_PATH/.git" ]] || die "not a git repository: $REPO_PATH"

    # If resuming, skip ticket resolution
    if [[ -n "$RESUME_PATH" ]]; then
        return
    fi

    # Smart ticket resolution: auto-detect type from the raw input
    [[ -n "$ticket_raw" ]] || die "no ticket provided (use --ticket)"

    if [[ "$ticket_raw" =~ ^https://github\.com/([^/]+/[^/]+)/issues/([0-9]+) ]]; then
        # GitHub issue URL → fetch via gh
        local gh_ref="${BASH_REMATCH[1]}#${BASH_REMATCH[2]}"
        info "fetching GitHub issue ${gh_ref}..."
        TICKET=$(gh issue view "$gh_ref" --json title,body --jq '"# " + .title + "\n\n" + .body') \
            || die "failed to fetch GitHub issue: $gh_ref"

    elif [[ "$ticket_raw" =~ ^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+#[0-9]+$ ]]; then
        # GitHub issue ref (owner/repo#42) → fetch via gh
        info "fetching GitHub issue ${ticket_raw}..."
        TICKET=$(gh issue view "$ticket_raw" --json title,body --jq '"# " + .title + "\n\n" + .body') \
            || die "failed to fetch GitHub issue: $ticket_raw"

    elif [[ -f "$ticket_raw" ]]; then
        # Existing file path → read contents
        info "reading ticket from file: ${ticket_raw}"
        TICKET=$(cat "$ticket_raw")
        [[ -n "$TICKET" ]] || die "ticket file is empty: $ticket_raw"

    else
        # Plain text description
        TICKET="$ticket_raw"
    fi
}

# ─── Worktree Setup ─────────────────────────────────────────────────────────

setup_worktree() {
    local timestamp
    timestamp=$(date +%Y%m%d-%H%M%S)
    BRANCH_NAME="swarm/${timestamp}"
    WORKTREE_PATH="${REPO_PATH}/../$(basename "$REPO_PATH")-swarm-${timestamp}"

    info "creating worktree at $WORKTREE_PATH (branch: $BRANCH_NAME)"
    git -C "$REPO_PATH" worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH" \
        || die "failed to create worktree"

    WORKTREE_PATH="$(cd "$WORKTREE_PATH" && pwd)"
    SWARM_RUNTIME="$WORKTREE_PATH/.swarm"
    mkdir -p "$SWARM_RUNTIME/prompts" "$SWARM_RUNTIME/log"

    # Write run metadata
    jq -n \
        --arg ticket "$TICKET" \
        --arg branch "$BRANCH_NAME" \
        --arg worktree "$WORKTREE_PATH" \
        --arg repo_path "$REPO_PATH" \
        --arg session_name "$SESSION_NAME" \
        --arg started "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '{ticket: $ticket, branch: $branch, worktree: $worktree, repo_path: $repo_path, session_name: $session_name, started: $started, cross_stage_retries: 0, retry_history: [], stages: {}}' \
        > "$SWARM_RUNTIME/run.json"

    success "worktree ready: $WORKTREE_PATH"
}

# ─── tmux Setup ──────────────────────────────────────────────────────────────

# Create just the tmux session (no layout yet)
create_tmux_session() {
    # Kill existing session if any
    "$TMUX_BIN" kill-session -t "$SESSION_NAME" 2>/dev/null || true

    # Create session with first pane (explicitly name window "main")
    "$TMUX_BIN" new-session -d -s "$SESSION_NAME" -n main -x 200 -y 50

    # Wait for session and window to be ready
    local wait_count=0
    while ! "$TMUX_BIN" has-session -t "$SESSION_NAME" 2>/dev/null; do
        sleep 0.1
        wait_count=$((wait_count + 1))
        [[ $wait_count -ge 30 ]] && die "tmux session failed to start"
    done

    # Wait for window to be available (use name since base-index may vary)
    wait_count=0
    while ! "$TMUX_BIN" list-windows -t "$SESSION_NAME" 2>/dev/null | grep -q 'main'; do
        sleep 0.1
        wait_count=$((wait_count + 1))
        [[ $wait_count -ge 30 ]] && die "tmux window failed to initialize"
    done

    # Enable pane border status with custom format
    "$TMUX_BIN" set-option -t "$SESSION_NAME" pane-border-status top
    "$TMUX_BIN" set-option -t "$SESSION_NAME" pane-border-format "#{pane_title}"
    # Prevent shell from overwriting pane titles
    "$TMUX_BIN" set-option -t "$SESSION_NAME" allow-rename off

    info "tmux session '$SESSION_NAME' created"
}

# Create the main + sidebar layout (call after viewer attaches)
setup_tmux_layout() {
    local stages
    stages=()
    while IFS= read -r line; do stages+=("$line"); done < <(get_pipeline)

    # Reset stage mappings
    STAGE_NAMES=()
    STAGE_PANES=()

    # Get the initial pane ID (this becomes the main pane, ~70% width)
    MAIN_PANE_ID=$("$TMUX_BIN" list-panes -t "${SESSION_NAME}:main" -F '#{pane_id}' | head -1)

    # First stage goes in main pane
    MAIN_PANE_STAGE="${stages[0]}"
    set_stage_pane "${stages[0]}" "$MAIN_PANE_ID"

    # Create sidebar pane (~30% width) via horizontal split
    # split-window focuses the new pane, so we can get its ID with display
    "$TMUX_BIN" split-window -t "$MAIN_PANE_ID" -h -p 30
    local sidebar_pane_id
    sidebar_pane_id=$("$TMUX_BIN" display -t "${SESSION_NAME}:main" -p '#{pane_id}')

    # Second stage goes in first sidebar slot
    if [[ ${#stages[@]} -ge 2 ]]; then
        set_stage_pane "${stages[1]}" "$sidebar_pane_id"
    fi

    # Split sidebar vertically for remaining stages (3, 4, 5...)
    # Use calculated percentages for even distribution
    local num_sidebar=$((${#stages[@]} - 1))  # stages in sidebar
    local split_target="$sidebar_pane_id"
    for ((i = 2; i < ${#stages[@]}; i++)); do
        # Calculate percentage: (remaining-1)/remaining to give to new pane
        local remaining=$((num_sidebar - (i - 2)))
        local pct=$(( (remaining - 1) * 100 / remaining ))
        "$TMUX_BIN" split-window -t "$split_target" -v -p "$pct"
        local new_pane_id
        # split-window focuses the new pane, get its ID
        new_pane_id=$("$TMUX_BIN" display -t "${SESSION_NAME}:main" -p '#{pane_id}')
        set_stage_pane "${stages[$i]}" "$new_pane_id"
        split_target="$new_pane_id"
    done

    # Initialize all pane borders with PENDING status
    for stage in "${stages[@]}"; do
        update_pane_border "$stage" "PENDING"
    done

    # Focus on main pane
    "$TMUX_BIN" select-pane -t "$MAIN_PANE_ID"

    PANE_COUNT=${#stages[@]}
    info "layout created with $PANE_COUNT panes (main + sidebar)"
}

# Legacy wrapper for compatibility
setup_tmux() {
    create_tmux_session
    setup_tmux_layout
}

# ─── Prompt Builders ─────────────────────────────────────────────────────────

build_prompt_reviewer() {
    cat <<EOF
# Ticket

$TICKET

# Instructions

Analyze this ticket and the codebase. Write your analysis to .swarm/review.md following the format in your system prompt.
EOF
}

build_prompt_architect() {
    local review
    review=$(cat "$SWARM_RUNTIME/review.md" 2>/dev/null || echo "(no review available)")

    cat <<EOF
# Ticket

$TICKET

# Reviewer's Analysis

$review

# Instructions

Create a detailed implementation plan based on the ticket and review. Write your plan to .swarm/plan.md following the format in your system prompt.
EOF
}

build_prompt_qa() {
    local plan
    plan=$(cat "$SWARM_RUNTIME/plan.md" 2>/dev/null || echo "(no plan available)")

    cat <<EOF
# Ticket

$TICKET

# Implementation Plan

$plan

# Instructions

Write tests based on the implementation plan (TDD). Tests should define expected behavior and will initially fail since no production code exists yet. Follow existing project test conventions. Commit your test files when done.
EOF
}

build_prompt_coder() {
    local plan
    plan=$(cat "$SWARM_RUNTIME/plan.md" 2>/dev/null || echo "(no plan available)")

    cat <<EOF
# Ticket

$TICKET

# Implementation Plan

$plan

# Instructions

Implement the solution following the plan step by step. Run the existing tests frequently — your goal is to make all tests pass. Follow project conventions. Commit your changes when done.
EOF
}

build_prompt_validator() {
    local review plan
    review=$(cat "$SWARM_RUNTIME/review.md" 2>/dev/null || echo "(no review available)")
    plan=$(cat "$SWARM_RUNTIME/plan.md" 2>/dev/null || echo "(no plan available)")

    cat <<EOF
# Ticket

$TICKET

# Reviewer's Analysis

$review

# Implementation Plan

$plan

# Instructions

Validate the implementation:
1. Run git diff against the base branch to review all changes
2. Run the full test suite
3. Verify the implementation matches the plan
4. Create a PR using: gh pr create
   - Title should summarize the change
   - Description should include: summary, test coverage notes, any caveats
EOF
}

build_stage_prompt() {
    local stage="$1"
    local prompt_file="$SWARM_RUNTIME/prompts/${stage}.txt"

    case "$stage" in
        reviewer)  build_prompt_reviewer  > "$prompt_file" ;;
        architect) build_prompt_architect > "$prompt_file" ;;
        qa)        build_prompt_qa        > "$prompt_file" ;;
        coder)     build_prompt_coder     > "$prompt_file" ;;
        validator) build_prompt_validator > "$prompt_file" ;;
        *)         die "unknown stage: $stage" ;;
    esac

    # Append retry feedback if present
    if [[ -n "$ACTIVE_FEEDBACK_FILE" ]] && [[ -f "$ACTIVE_FEEDBACK_FILE" ]]; then
        echo "" >> "$prompt_file"
        cat "$ACTIVE_FEEDBACK_FILE" >> "$prompt_file"
        info "appended retry feedback to ${stage} prompt"
    fi

    echo "$prompt_file"
}

# ─── Auth Environment ─────────────────────────────────────────────────────────

AUTH_ENV_VARS=(
    "AWS_PROFILE" "AWS_REGION" "AWS_ACCESS_KEY_ID" "AWS_SECRET_ACCESS_KEY"
    "AWS_SESSION_TOKEN" "CLAUDE_CODE_USE_BEDROCK" "ANTHROPIC_API_KEY"
    "ANTHROPIC_MODEL" "ANTHROPIC_SMALL_FAST_MODEL"
)

build_auth_env_prefix() {
    local env_prefix="env CLAUDECODE="  # Unset CLAUDECODE

    local var
    for var in "${AUTH_ENV_VARS[@]}"; do
        if [[ -n "${!var:-}" ]]; then
            env_prefix+=" ${var}=$(printf '%q' "${!var}")"
        fi
    done

    echo "$env_prefix"
}

# ─── Agent Dispatch ──────────────────────────────────────────────────────────

build_claude_cmd() {
    local stage="$1"
    local model budget prompt_file system_prompt log_file exitcode_file env_prefix

    model=$(get_stage_model "$stage")
    budget=$(get_stage_budget "$stage")
    prompt_file="$SWARM_RUNTIME/prompts/${stage}.txt"
    system_prompt="$ROLES_DIR/${stage}.md"
    log_file="$SWARM_RUNTIME/log/${stage}.log"
    exitcode_file="$SWARM_RUNTIME/log/${stage}.exitcode"
    env_prefix=$(build_auth_env_prefix)

    # Build the command that runs in the tmux pane
    # Status is shown via pane border, not echoed
    cat <<EOF
cd ${WORKTREE_PATH} && \\
${env_prefix} ${CLAUDE} -p \\
  --model ${model} \\
  --max-budget-usd ${budget} \\
  --dangerously-skip-permissions \\
  --output-format text \\
  --system-prompt "\$(cat ${system_prompt})" \\
  "\$(cat ${prompt_file})" \\
  2>&1 | tee ${log_file}; \\
echo \${PIPESTATUS[0]:-\${pipestatus[1]}} > ${exitcode_file}
EOF
}

# Extensible dispatch — add new agent types here
build_agent_cmd() {
    local stage="$1"
    local agent_type="${2:-claude}"

    case "$agent_type" in
        claude) build_claude_cmd "$stage" ;;
        # Future agent types:
        # codex)  build_codex_cmd "$stage" ;;
        # kimi)   build_kimi_cmd "$stage" ;;
        *)      die "unknown agent type: $agent_type" ;;
    esac
}

# ─── Stage Output Validation ─────────────────────────────────────────────────

validate_stage_output() {
    local stage="$1"

    case "$stage" in
        reviewer)
            if [[ ! -s "$SWARM_RUNTIME/review.md" ]]; then
                warn "validation failed: .swarm/review.md is missing or empty"
                return 1
            fi
            ;;
        architect)
            if [[ ! -s "$SWARM_RUNTIME/plan.md" ]]; then
                warn "validation failed: .swarm/plan.md is missing or empty"
                return 1
            fi
            ;;
        qa)
            local pre_sha
            pre_sha=$(jq -r --arg s "$stage" '.stages[$s].pre_sha // empty' "$SWARM_RUNTIME/run.json")
            if [[ -n "$pre_sha" ]]; then
                local changed_files
                changed_files=$(git -C "$WORKTREE_PATH" diff --name-only "$pre_sha" HEAD 2>/dev/null || true)
                if [[ -z "$changed_files" ]]; then
                    warn "validation failed: qa stage produced no file changes"
                    return 1
                fi
            fi
            ;;
        coder)
            local pre_sha
            pre_sha=$(jq -r --arg s "$stage" '.stages[$s].pre_sha // empty' "$SWARM_RUNTIME/run.json")
            if [[ -n "$pre_sha" ]]; then
                local non_test_files
                non_test_files=$(git -C "$WORKTREE_PATH" diff --name-only "$pre_sha" HEAD 2>/dev/null \
                    | grep -v -E '(test|spec|_test\.|\.test\.)' || true)
                if [[ -z "$non_test_files" ]]; then
                    warn "validation failed: coder stage produced no non-test file changes"
                    return 1
                fi
            fi
            ;;
        validator)
            local pr_count
            pr_count=$(gh pr list --repo "$REPO_PATH" --head "$BRANCH_NAME" --json number --jq 'length' 2>/dev/null || echo "0")
            if [[ "$pr_count" -eq 0 ]]; then
                warn "validation failed: no PR found for branch $BRANCH_NAME"
                return 1
            fi
            ;;
    esac

    return 0
}

# ─── Stage Runner ────────────────────────────────────────────────────────────

run_stage() {
    local stage="$1"
    local stage_index="$2"
    local pane_id
    pane_id=$(get_stage_pane "$stage")
    local exitcode_file="$SWARM_RUNTIME/log/${stage}.exitcode"
    local start_time elapsed

    # Swap this stage into the main pane
    swap_to_main "$stage"
    # Re-fetch pane_id after swap (may have changed)
    pane_id=$(get_stage_pane "$stage")

    # Clean stale exitcode file to support re-runs
    rm -f "$exitcode_file"

    # Record pre_sha for git-diff-based validation
    local pre_sha
    pre_sha=$(git -C "$WORKTREE_PATH" rev-parse HEAD 2>/dev/null || echo "")

    # Build prompt file for this stage
    build_stage_prompt "$stage"

    # Build agent command
    local cmd
    cmd=$(build_agent_cmd "$stage")

    # Update pane border to RUNNING
    update_pane_border "$stage" "RUNNING"

    # Update run metadata with pre_sha
    local tmp
    tmp=$(mktemp)
    jq --arg s "$stage" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --arg sha "$pre_sha" \
        '.stages[$s] = {status: "running", started: $t, pre_sha: $sha}' \
        "$SWARM_RUNTIME/run.json" > "$tmp" && mv "$tmp" "$SWARM_RUNTIME/run.json"

    info "starting stage: ${stage}"

    # Send command to the pane
    "$TMUX_BIN" send-keys -t "$pane_id" "$cmd" Enter

    # Poll for completion
    start_time=$(date +%s)
    while true; do
        if [[ -f "$exitcode_file" ]]; then
            local exit_code
            exit_code=$(cat "$exitcode_file" | tr -d '[:space:]')

            # Guard against empty exit code (e.g. shell compatibility issues)
            if [[ -z "$exit_code" ]]; then
                exit_code=1
            fi

            if [[ "$exit_code" == "0" ]]; then
                # Validate stage output before marking done
                if ! validate_stage_output "$stage"; then
                    tmp=$(mktemp)
                    jq --arg s "$stage" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
                        '.stages[$s].status = "validation_failed" | .stages[$s].finished = $t | .stages[$s].exit_code = 0' \
                        "$SWARM_RUNTIME/run.json" > "$tmp" && mv "$tmp" "$SWARM_RUNTIME/run.json"

                    update_pane_border "$stage" "VALIDATION_FAILED"
                    return 1
                fi

                # Update run metadata
                tmp=$(mktemp)
                jq --arg s "$stage" --arg c "$exit_code" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
                    '.stages[$s].status = "done" | .stages[$s].exit_code = ($c | tonumber) | .stages[$s].finished = $t' \
                    "$SWARM_RUNTIME/run.json" > "$tmp" && mv "$tmp" "$SWARM_RUNTIME/run.json"

                update_pane_border "$stage" "DONE"
                success "stage ${stage} completed successfully"
                return 0
            else
                # Update run metadata for failure
                tmp=$(mktemp)
                jq --arg s "$stage" --arg c "$exit_code" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
                    '.stages[$s].status = "failed" | .stages[$s].exit_code = ($c | tonumber) | .stages[$s].finished = $t' \
                    "$SWARM_RUNTIME/run.json" > "$tmp" && mv "$tmp" "$SWARM_RUNTIME/run.json"

                update_pane_border "$stage" "FAILED" "(exit ${exit_code})"
                warn "stage ${stage} failed with exit code ${exit_code}"
                return 1
            fi
        fi

        # Check timeout
        elapsed=$(( $(date +%s) - start_time ))
        if [[ $elapsed -ge $STAGE_TIMEOUT ]]; then
            update_pane_border "$stage" "TIMEOUT"

            tmp=$(mktemp)
            jq --arg s "$stage" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
                '.stages[$s].status = "timeout" | .stages[$s].finished = $t' \
                "$SWARM_RUNTIME/run.json" > "$tmp" && mv "$tmp" "$SWARM_RUNTIME/run.json"

            warn "stage ${stage} timed out after ${STAGE_TIMEOUT}s"
            return 1
        fi

        sleep "$POLL_INTERVAL"
    done
}

# ─── Checkpoint & Resume ─────────────────────────────────────────────────────

restore_from_checkpoint() {
    local worktree_path="$1"

    worktree_path="$(cd "$worktree_path" 2>/dev/null && pwd)" || die "invalid worktree path: $worktree_path"

    SWARM_RUNTIME="$worktree_path/.swarm"
    [[ -f "$SWARM_RUNTIME/run.json" ]] || die "no run.json found in $SWARM_RUNTIME"

    # Restore state from run.json
    TICKET=$(jq -r '.ticket // empty' "$SWARM_RUNTIME/run.json")
    BRANCH_NAME=$(jq -r '.branch // empty' "$SWARM_RUNTIME/run.json")
    WORKTREE_PATH=$(jq -r '.worktree // empty' "$SWARM_RUNTIME/run.json")
    REPO_PATH=$(jq -r '.repo_path // empty' "$SWARM_RUNTIME/run.json")

    local saved_session
    saved_session=$(jq -r '.session_name // empty' "$SWARM_RUNTIME/run.json")
    if [[ -n "$saved_session" ]]; then
        SESSION_NAME="$saved_session"
    fi

    # Restore cross-stage retry count
    CROSS_STAGE_RETRY_COUNT=$(jq -r '.cross_stage_retries // 0' "$SWARM_RUNTIME/run.json")

    [[ -n "$TICKET" ]] || die "run.json missing ticket"
    [[ -n "$BRANCH_NAME" ]] || die "run.json missing branch"
    [[ -n "$WORKTREE_PATH" ]] || die "run.json missing worktree"

    # Remove interrupted marker
    local tmp
    tmp=$(mktemp)
    jq 'del(.interrupted)' "$SWARM_RUNTIME/run.json" > "$tmp" && mv "$tmp" "$SWARM_RUNTIME/run.json"

    info "restored checkpoint from: $WORKTREE_PATH"
    info "branch: $BRANCH_NAME"
    info "ticket: $(echo "$TICKET" | head -c 80)..."
}

restore_border_colors() {
    local stages
    stages=()
    while IFS= read -r line; do stages+=("$line"); done < <(get_pipeline)

    # Restore border colors from run.json stage statuses
    for stage in "${stages[@]}"; do
        local status
        status=$(jq -r --arg s "$stage" '.stages[$s].status // "pending"' "$SWARM_RUNTIME/run.json")
        case "$status" in
            done)              update_pane_border "$stage" "DONE" ;;
            failed)            update_pane_border "$stage" "FAILED" ;;
            timeout)           update_pane_border "$stage" "TIMEOUT" ;;
            validation_failed) update_pane_border "$stage" "VALIDATION_FAILED" ;;
            running)           update_pane_border "$stage" "PENDING" ;;  # Reset running to pending
            *)                 update_pane_border "$stage" "PENDING" ;;
        esac
    done
}

run_pipeline_resume() {
    local stages
    stages=()
    while IFS= read -r line; do stages+=("$line"); done < <(get_pipeline)

    info "resuming pipeline: ${stages[*]}"
    info "ticket: $(echo "$TICKET" | head -c 80)..."

    local i=0
    while [[ $i -lt ${#stages[@]} ]]; do
        local stage="${stages[$i]}"

        # Check if stage was already completed
        local stage_status
        stage_status=$(jq -r --arg s "$stage" '.stages[$s].status // "pending"' "$SWARM_RUNTIME/run.json")

        if [[ "$stage_status" == "done" ]]; then
            info "skipping completed stage: ${stage}"
            # Border already set by setup_tmux_for_resume
            i=$((i + 1))
            continue
        fi

        info "resuming from stage: ${stage}"

        if ! run_stage_with_retries "$stage" "$i"; then
            echo
            warn "pipeline halted at stage: ${stage}"
            warn "worktree preserved at: $WORKTREE_PATH"
            warn "logs: $SWARM_RUNTIME/log/"
            warn "resume with: swarm $(printf '%q' "$REPO_PATH") --resume $(printf '%q' "$WORKTREE_PATH")"
            warn "attach: tmux attach -t $SESSION_NAME"
            exit 1
        fi

        # Check for verdict.json (cross-stage retry)
        local retry_target
        retry_target=$(check_verdict "$stage" "${stages[@]}")
        if [[ -n "$retry_target" ]]; then
            # Find the index of the retry target stage
            local j
            for ((j = 0; j < ${#stages[@]}; j++)); do
                if [[ "${stages[$j]}" == "$retry_target" ]]; then
                    i=$j
                    break
                fi
            done
            continue
        fi

        i=$((i + 1))
    done

    echo
    success "pipeline completed successfully!"
    success "worktree: $WORKTREE_PATH"
    success "branch: $BRANCH_NAME"
    info "attach to review: tmux attach -t $SESSION_NAME"
}

# ─── Auth Failure Detection ──────────────────────────────────────────────────

AUTH_FAILURE_PATTERNS=(
    "Authentication failed" "Invalid API key" "Unauthorized" "401" "403"
    "ExpiredToken" "ExpiredTokenException" "InvalidAccessKeyId" "AccessDenied"
    "cannot be launched inside another Claude Code session"
)

is_auth_failure() {
    local log_file="$1"
    [[ -f "$log_file" ]] || return 1

    local pattern
    for pattern in "${AUTH_FAILURE_PATTERNS[@]}"; do
        if grep -qi "$pattern" "$log_file" 2>/dev/null; then
            echo "$pattern"
            return 0
        fi
    done
    return 1
}

# ─── Transient Retries ───────────────────────────────────────────────────────

run_stage_with_retries() {
    local stage="$1"
    local stage_index="$2"
    local max_retries
    max_retries=$(get_stage_max_retries "$stage")

    # Load backoff values from config
    local backoffs
    backoffs=()
    while IFS= read -r line; do backoffs+=("$line"); done < <(get_retry_backoffs)

    local attempt=0
    while true; do
        attempt=$((attempt + 1))

        if run_stage "$stage" "$stage_index"; then
            return 0
        fi

        # Check for auth failure — do not retry
        local log_file="$SWARM_RUNTIME/log/${stage}.log"
        local auth_match
        if auth_match=$(is_auth_failure "$log_file"); then
            warn "auth failure detected (${auth_match}) — not retrying"
            return 1
        fi

        # Check if we've exhausted retries
        if [[ $attempt -ge $max_retries ]]; then
            warn "stage ${stage} failed after ${attempt} attempt(s) — no retries left"
            return 1
        fi

        # Archive the failed log
        if [[ -f "$log_file" ]]; then
            cp "$log_file" "$SWARM_RUNTIME/log/${stage}.attempt${attempt}.log"
        fi

        # Get backoff duration (clamp to array bounds)
        local backoff_index=$((attempt - 1))
        if [[ $backoff_index -ge ${#backoffs[@]} ]]; then
            backoff_index=$(( ${#backoffs[@]} - 1 ))
        fi
        local backoff="${backoffs[$backoff_index]}"

        # Update run.json with retry status
        local tmp
        tmp=$(mktemp)
        jq --arg s "$stage" --argjson r "$attempt" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.stages[$s].status = "retrying" | .stages[$s].retries = $r | .stages[$s].last_retry = $t' \
            "$SWARM_RUNTIME/run.json" > "$tmp" && mv "$tmp" "$SWARM_RUNTIME/run.json"

        # Show retry status in pane border
        warn "stage ${stage} failed (attempt ${attempt}/${max_retries}) — retrying in ${backoff}s"
        update_pane_border "$stage" "RETRY" "${attempt}/${max_retries}"

        sleep "$backoff"
    done
}

# ─── Cross-Stage Retry (verdict.json) ────────────────────────────────────────

build_retry_feedback_section() {
    local retry_from="$1"
    local reason="$2"
    local feedback="$3"
    local loop_num="$4"

    local feedback_file="$SWARM_RUNTIME/prompts/retry_feedback_${loop_num}.md"

    {
        echo "# Retry Feedback (Loop ${loop_num})"
        echo ""
        echo "A previous pipeline run identified issues that require rework."
        echo ""
        echo "## Reason"
        echo ""
        echo "$reason"
        echo ""
        echo "## Detailed Feedback"
        echo ""
        echo "$feedback"
        echo ""

        # Include tail of the stage log that triggered the retry
        local prev_log="$SWARM_RUNTIME/log/validator.log"
        if [[ -f "$prev_log" ]]; then
            echo "## Relevant Log Tail"
            echo ""
            echo '```'
            tail -50 "$prev_log" 2>/dev/null || true
            echo '```'
        fi
    } > "$feedback_file"

    echo "$feedback_file"
}

# check_verdict — reads verdict.json after a successful stage
# Prints the retry_from stage name if a retry is needed, empty otherwise.
# Also sets ACTIVE_FEEDBACK_FILE as a side effect.
check_verdict() {
    local current_stage="$1"
    shift
    local stages=("$@")

    local verdict_file="$SWARM_RUNTIME/verdict.json"

    if [[ ! -f "$verdict_file" ]]; then
        return 0
    fi

    # Read verdict fields
    local retry_from reason feedback
    retry_from=$(jq -r '.retry_from // empty' "$verdict_file")
    reason=$(jq -r '.reason // "no reason given"' "$verdict_file")
    feedback=$(jq -r '.feedback // ""' "$verdict_file")

    if [[ -z "$retry_from" ]]; then
        rm -f "$verdict_file"
        return 0
    fi

    # Validate retry_from is a known stage
    local valid=false
    local target_idx=-1
    local current_idx=-1
    for ((k = 0; k < ${#stages[@]}; k++)); do
        if [[ "${stages[$k]}" == "$retry_from" ]]; then
            valid=true
            target_idx=$k
        fi
        if [[ "${stages[$k]}" == "$current_stage" ]]; then
            current_idx=$k
        fi
    done

    if [[ "$valid" != "true" ]]; then
        warn "verdict.json: invalid retry_from stage '${retry_from}' — ignoring"
        rm -f "$verdict_file"
        return 0
    fi

    # Prevent forward retries
    if [[ $target_idx -gt $current_idx ]]; then
        warn "verdict.json: cannot retry forward to '${retry_from}' from '${current_stage}' — ignoring"
        rm -f "$verdict_file"
        return 0
    fi

    # Load max from config
    local max_loops
    max_loops=$(get_max_cross_stage_retries)

    # Check retry limit
    if [[ $CROSS_STAGE_RETRY_COUNT -ge $max_loops ]]; then
        warn "verdict.json: max cross-stage retries ($max_loops) reached — ignoring verdict"
        rm -f "$verdict_file"
        return 0
    fi

    CROSS_STAGE_RETRY_COUNT=$((CROSS_STAGE_RETRY_COUNT + 1))
    info "cross-stage retry ${CROSS_STAGE_RETRY_COUNT}/${max_loops}: looping back to '${retry_from}' — ${reason}"

    # Archive verdict
    cp "$verdict_file" "$SWARM_RUNTIME/log/verdict.${CROSS_STAGE_RETRY_COUNT}.json"
    rm -f "$verdict_file"

    # Update run.json
    local tmp
    tmp=$(mktemp)
    jq --argjson c "$CROSS_STAGE_RETRY_COUNT" \
        --arg from "$retry_from" --arg r "$reason" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '.cross_stage_retries = $c | .retry_history += [{ loop: $c, retry_from: $from, reason: $r, timestamp: $t }]' \
        "$SWARM_RUNTIME/run.json" > "$tmp" && mv "$tmp" "$SWARM_RUNTIME/run.json"

    # Archive logs for stages that will be re-run
    for ((k = target_idx; k <= current_idx; k++)); do
        local s="${stages[$k]}"
        local log="$SWARM_RUNTIME/log/${s}.log"
        if [[ -f "$log" ]]; then
            cp "$log" "$SWARM_RUNTIME/log/${s}.pre_retry_${CROSS_STAGE_RETRY_COUNT}.log"
        fi
        # Reset exitcode so stage can re-run
        rm -f "$SWARM_RUNTIME/log/${s}.exitcode"
        # Reset stage status in run.json
        tmp=$(mktemp)
        jq --arg s "$s" '.stages[$s].status = "pending"' \
            "$SWARM_RUNTIME/run.json" > "$tmp" && mv "$tmp" "$SWARM_RUNTIME/run.json"
    done

    # Build feedback file for the retried stage
    ACTIVE_FEEDBACK_FILE=$(build_retry_feedback_section "$retry_from" "$reason" "$feedback" "$CROSS_STAGE_RETRY_COUNT")

    echo "$retry_from"
}

# ─── Pipeline Loop ───────────────────────────────────────────────────────────

run_pipeline() {
    local stages
    stages=()
    while IFS= read -r line; do stages+=("$line"); done < <(get_pipeline)

    info "pipeline: ${stages[*]}"
    info "ticket: $(echo "$TICKET" | head -c 80)..."

    local i=0
    while [[ $i -lt ${#stages[@]} ]]; do
        local stage="${stages[$i]}"

        # Remove stale verdict.json at top of each iteration
        rm -f "$SWARM_RUNTIME/verdict.json"

        if ! run_stage_with_retries "$stage" "$i"; then
            echo
            warn "pipeline halted at stage: ${stage}"
            warn "worktree preserved at: $WORKTREE_PATH"
            warn "logs: $SWARM_RUNTIME/log/"
            warn "resume with: swarm $(printf '%q' "$REPO_PATH") --resume $(printf '%q' "$WORKTREE_PATH")"
            warn "attach: tmux attach -t $SESSION_NAME"
            exit 1
        fi

        # Check for verdict.json (cross-stage retry)
        local retry_target
        retry_target=$(check_verdict "$stage" "${stages[@]}")
        if [[ -n "$retry_target" ]]; then
            # Find the index of the retry target stage
            local j
            for ((j = 0; j < ${#stages[@]}; j++)); do
                if [[ "${stages[$j]}" == "$retry_target" ]]; then
                    i=$j
                    break
                fi
            done
            continue
        fi

        # Clear feedback file after stage consumes it
        ACTIVE_FEEDBACK_FILE=""

        i=$((i + 1))
    done

    echo
    success "pipeline completed successfully!"
    success "worktree: $WORKTREE_PATH"
    success "branch: $BRANCH_NAME"
    info "attach to review: tmux attach -t $SESSION_NAME"
}

# ─── Auto-Attach Viewer ───────────────────────────────────────────────────────

open_tmux_viewer() {
    local attach_cmd="$TMUX_BIN attach -t $SESSION_NAME"

    # Detect terminal emulator (check env vars that persist inside tmux)
    local terminal=""
    if [[ -n "${GHOSTTY_BIN_DIR:-}" ]] || [[ "$TERM_PROGRAM" == "ghostty" ]]; then
        terminal="ghostty"
    elif [[ -n "${ITERM_SESSION_ID:-}" ]] || [[ "$TERM_PROGRAM" == "iTerm.app" ]]; then
        terminal="iterm"
    elif [[ "$TERM_PROGRAM" == "Apple_Terminal" ]]; then
        terminal="terminal"
    fi

    case "$terminal" in
        ghostty)
            # Use Ghostty CLI to open new window with tmux attach
            # Each arg must be passed separately — Ghostty's -e doesn't accept a single string
            open -na Ghostty.app --args -e "$TMUX_BIN" attach -t "$SESSION_NAME"
            info "opened Ghostty window with tmux viewer"
            ;;
        iterm)
            osascript &>/dev/null <<EOF
tell application "iTerm"
    tell current window
        create tab with default profile
        tell current session
            write text "$attach_cmd"
        end tell
    end tell
end tell
EOF
            info "opened iTerm2 tab with tmux viewer"
            ;;
        terminal)
            osascript &>/dev/null <<EOF
tell application "Terminal"
    activate
    tell application "System Events" to keystroke "t" using command down
    delay 0.3
    do script "$attach_cmd" in front window
end tell
EOF
            info "opened Terminal tab with tmux viewer"
            ;;
        *)
            info "attach with: tmux attach -t $SESSION_NAME"
            ;;
    esac
}

# ─── Cleanup ─────────────────────────────────────────────────────────────────

cleanup() {
    # On interrupt, update run metadata but preserve worktree
    if [[ -n "${SWARM_RUNTIME:-}" ]] && [[ -f "$SWARM_RUNTIME/run.json" ]]; then
        local tmp
        tmp=$(mktemp)
        jq --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.interrupted = $t' \
            "$SWARM_RUNTIME/run.json" > "$tmp" && mv "$tmp" "$SWARM_RUNTIME/run.json"
    fi
    warn "interrupted — worktree preserved at: ${WORKTREE_PATH:-unknown}"
    if [[ -n "${WORKTREE_PATH:-}" ]] && [[ -n "${REPO_PATH:-}" ]]; then
        warn "resume with: swarm $(printf '%q' "$REPO_PATH") --resume $(printf '%q' "$WORKTREE_PATH")"
    fi
    exit 130
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
    check_prerequisites
    check_auth
    parse_args "$@"

    trap cleanup INT TERM

    if [[ -n "$RESUME_PATH" ]]; then
        restore_from_checkpoint "$RESUME_PATH"
        create_tmux_session
        open_tmux_viewer
        sleep 1  # Wait for viewer to attach and resize session
        setup_tmux_layout
        restore_border_colors
        run_pipeline_resume
    else
        setup_worktree
        create_tmux_session
        open_tmux_viewer
        sleep 1  # Wait for viewer to attach and resize session
        setup_tmux_layout
        run_pipeline
    fi
}

main "$@"
